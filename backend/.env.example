# Copy to .env for local development (never commit .env).

# PostgreSQL (Render Postgres provides this as DATABASE_URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Auth (use a long random string in production)
JWT_SECRET=

# Comma-separated browser origins allowed by CORS (your Vercel URL, etc.)
# Example: https://smartsched.vercel.app,https://www.example.com
FRONTEND_ORIGINS=

# Optional; Render sets PORT automatically
# PORT=3000
